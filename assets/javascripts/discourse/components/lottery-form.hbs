<div class="lottery-form">
  <div class="lottery-form-header">
    <h3>🎲 创建抽奖活动</h3>
    <p class="lottery-form-description">
      请填写以下信息创建抽奖活动。所有标有 <span class="required">*</span> 的字段都是必填的。
    </p>
  </div>

  <div class="lottery-form-body">
    <!-- 活动名称 -->
    <div class="field-group">
      <label class="field-label required">活动名称 *</label>
      <input 
        type="text" 
        class="lottery-input"
        value={{this.prizeName}}
        placeholder="请输入活动名称"
        {{on "input" this.updatePrizeName}}
      />
      {{#if this.errors.prizeName}}
        <div class="field-error">{{this.errors.prizeName}}</div>
      {{/if}}
    </div>

    <!-- 奖品说明 -->
    <div class="field-group">
      <label class="field-label required">奖品说明 *</label>
      <textarea 
        class="lottery-textarea"
        value={{this.prizeDetails}}
        rows="3"
        placeholder="请详细描述奖品内容"
        {{on "input" this.updatePrizeDetails}}
      ></textarea>
      {{#if this.errors.prizeDetails}}
        <div class="field-error">{{this.errors.prizeDetails}}</div>
      {{/if}}
    </div>

    <!-- 开奖时间 -->
    <div class="field-group">
      <label class="field-label required">开奖时间 *</label>
      <input 
        type="datetime-local" 
        class="lottery-input"
        value={{this.drawTime}}
        {{on "input" this.updateDrawTime}}
      />
      {{#if this.errors.drawTime}}
        <div class="field-error">{{this.errors.drawTime}}</div>
      {{/if}}
    </div>

    <!-- 获奖人数 -->
    <div class="field-group">
      <label class="field-label required">获奖人数 *</label>
      <input 
        type="number" 
        class="lottery-input"
        value={{this.winnersCount}}
        min="1"
        {{on "input" this.updateWinnersCount}}
      />
      <div class="field-help">这是随机抽奖时的获奖人数。如果您想按指定楼层开奖，请填写下面的"指定中奖楼层"项。</div>
      {{#if this.errors.winnersCount}}
        <div class="field-error">{{this.errors.winnersCount}}</div>
      {{/if}}
    </div>

    <!-- 指定中奖楼层 -->
    <div class="field-group">
      <label class="field-label">指定中奖楼层（可选）</label>
      <input 
        type="text" 
        class="lottery-input"
        value={{this.specifiedPosts}}
        placeholder="例如：8, 18, 28"
        {{on "input" this.updateSpecifiedPosts}}
      />
      <div class="field-help">填写此项将覆盖随机抽奖。请填写具体的楼层号，用英文逗号分隔。</div>
      {{#if this.errors.specifiedPosts}}
        <div class="field-error">{{this.errors.specifiedPosts}}</div>
      {{/if}}
    </div>

    <!-- 参与门槛 -->
    <div class="field-group">
      <label class="field-label required">参与门槛 *</label>
      <input 
        type="number" 
        class="lottery-input"
        value={{this.minParticipants}}
        min={{this.globalMinParticipants}}
        {{on "input" this.updateMinParticipants}}
      />
      <div class="field-help">最少需要 {{this.globalMinParticipants}} 人参与</div>
      {{#if this.errors.minParticipants}}
        <div class="field-error">{{this.errors.minParticipants}}</div>
      {{/if}}
    </div>

    <!-- 后备策略 -->
    <div class="field-group">
      <label class="field-label required">后备策略 *</label>
      <select 
        class="lottery-select"
        {{on "change" this.updateBackupStrategy}}
      >
        <option value="continue" selected={{eq this.backupStrategy "continue"}}>
          当开奖时人数不足，继续开奖
        </option>
        <option value="cancel" selected={{eq this.backupStrategy "cancel"}}>
          当开奖时人数不足，取消活动
        </option>
      </select>
    </div>

    <!-- 补充说明 -->
    <div class="field-group">
      <label class="field-label">补充说明（可选）</label>
      <textarea 
        class="lottery-textarea"
        value={{this.additionalNotes}}
        rows="2"
        placeholder="其他需要说明的内容"
        {{on "input" this.updateAdditionalNotes}}
      ></textarea>
    </div>
  </div>

  <!-- 表单状态提示 -->
  <div class="lottery-form-footer">
    {{#unless this.isFormValid}}
      <div class="form-status error">
        请完成所有必填项并修正错误后再提交
      </div>
    {{else}}
      <div class="form-status success">
        表单填写完整，可以提交
      </div>
    {{/unless}}
  </div>
</div>
