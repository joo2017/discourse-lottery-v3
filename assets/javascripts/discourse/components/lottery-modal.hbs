<DModal 
  @title="创建抽奖活动" 
  @closeModal={{@closeModal}} 
  class="lottery-modal"
>
  <:body>
    <div class="lottery-form">
      <!-- 活动名称 -->
      <div class="control-group">
        <label>活动名称 *</label>
        <Input 
          @value={{this.prizeName}}
          @input={{this.updatePrizeName}}
          placeholder="请输入活动名称"
          class="lottery-input"
        />
      </div>

      <!-- 奖品说明 -->
      <div class="control-group">
        <label>奖品说明 *</label>
        <Textarea 
          @value={{this.prizeDetails}}
          @input={{this.updatePrizeDetails}}
          placeholder="请详细描述奖品内容"
          @rows="3"
          class="lottery-textarea"
        />
      </div>

      <!-- 开奖时间 -->
      <div class="control-group">
        <label>开奖时间 *</label>
        <input 
          type="datetime-local" 
          value={{this.drawTime}}
          {{on "input" this.updateDrawTime}}
          class="lottery-input"
        />
      </div>

      <!-- 获奖人数 -->
      <div class="control-group">
        <label>获奖人数 *</label>
        <Input 
          @type="number"
          @value={{this.winnersCount}}
          @input={{this.updateWinnersCount}}
          @min="1"
          class="lottery-input"
        />
        <div class="form-help">随机抽奖时的获奖人数</div>
      </div>

      <!-- 指定中奖楼层 -->
      <div class="control-group">
        <label>指定中奖楼层（可选）</label>
        <Input 
          @value={{this.specifiedPosts}}
          @input={{this.updateSpecifiedPosts}}
          placeholder="例如：8, 18, 28"
          class="lottery-input"
        />
        <div class="form-help">填写此项将覆盖随机抽奖</div>
      </div>

      <!-- 参与门槛 -->
      <div class="control-group">
        <label>参与门槛 *</label>
        <Input 
          @type="number"
          @value={{this.minParticipants}}
          @input={{this.updateMinParticipants}}
          @min={{this.globalMinParticipants}}
          class="lottery-input"
        />
        <div class="form-help">最少需要 {{this.globalMinParticipants}} 人参与</div>
      </div>

      <!-- 后备策略 -->
      <div class="control-group">
        <label>后备策略 *</label>
        <select 
          {{on "change" this.updateBackupStrategy}}
          class="lottery-select"
        >
          <option value="continue" selected={{eq this.backupStrategy "continue"}}>
            当开奖时人数不足，继续开奖
          </option>
          <option value="cancel" selected={{eq this.backupStrategy "cancel"}}>
            当开奖时人数不足，取消活动
          </option>
        </select>
      </div>

      <!-- 补充说明 -->
      <div class="control-group">
        <label>补充说明（可选）</label>
        <Textarea 
          @value={{this.additionalNotes}}
          @input={{this.updateAdditionalNotes}}
          placeholder="其他需要说明的内容"
          @rows="2"
          class="lottery-textarea"
        />
      </div>
    </div>
  </:body>

  <:footer>
    <DButton 
      @action={{this.insertLottery}}
      @disabled={{not this.isFormValid}}
      @class="btn-primary"
      @label="创建抽奖"
    />
    <DButton 
      @action={{this.closeModal}}
      @class="btn-default"
      @label="取消"
    />
  </:footer>
</DModal>

<style>
.lottery-modal {
  width: 600px;
}

.lottery-form .control-group {
  margin-bottom: 15px;
}

.lottery-form label {
  font-weight: bold;
  margin-bottom: 5px;
  display: block;
}

.lottery-form .lottery-input,
.lottery-form .lottery-textarea,
.lottery-form .lottery-select {
  width: 100%;
  padding: 8px;
  border: 1px solid #ddd;
  border-radius: 4px;
  box-sizing: border-box;
}

.lottery-form .form-help {
  font-size: 12px;
  color: #666;
  margin-top: 3px;
}
</style>
