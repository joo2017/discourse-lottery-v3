{{#d-modal-body title="创建抽奖活动" class="lottery-form-modal"}}
  <div class="lottery-form">
    <div class="lottery-form-description">
      <p>填写抽奖活动信息，系统将自动在主题中显示抽奖详情并在指定时间开奖。</p>
    </div>

    <div class="control-group">
      <label class="control-label">活动名称 <span class="required">*</span></label>
      <div class="controls">
        {{input 
          value=prizeName 
          placeholder="例如：iPhone 15 Pro 抽奖"
          class="lottery-input"
          maxlength="100"
        }}
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">奖品说明 <span class="required">*</span></label>
      <div class="controls">
        {{textarea 
          value=prizeDetails 
          placeholder="详细描述奖品内容，如颜色、规格、数量等"
          class="lottery-textarea"
          rows="3"
          maxlength="500"
        }}
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">开奖时间 <span class="required">*</span></label>
      <div class="controls">
        {{input 
          value=drawTime 
          type="datetime-local"
          class="lottery-input"
        }}
        <div class="help-text">请选择未来的时间点，系统将在此时间自动开奖</div>
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">获奖人数</label>
      <div class="controls">
        {{number-input 
          value=winnersCount 
          min="1"
          max="100"
          class="lottery-input"
        }}
        <div class="help-text">随机抽奖的获奖人数。如果填写了"指定楼层"，此项将被忽略</div>
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">指定中奖楼层（可选）</label>
      <div class="controls">
        {{input 
          value=specifiedPosts 
          placeholder="例如：8,18,28"
          class="lottery-input"
        }}
        <div class="help-text">填写此项将覆盖随机抽奖。用英文逗号分隔楼层号</div>
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">参与门槛 <span class="required">*</span></label>
      <div class="controls">
        {{number-input 
          value=minParticipants 
          min=(or model.siteSettings.lottery_min_participants_global 5)
          max="1000"
          class="lottery-input"
        }}
        <div class="help-text">
          最少需要多少人参与才能开奖（不能低于全局设置：{{or model.siteSettings.lottery_min_participants_global 5}} 人）
        </div>
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">后备策略 <span class="required">*</span></label>
      <div class="controls">
        {{combo-box 
          value=backupStrategy
          content=(array 
            (hash id="continue" name="人数不足时继续开奖")
            (hash id="cancel" name="人数不足时取消活动")
          )
          class="lottery-select"
        }}
        <div class="help-text">当实际参与人数少于门槛时的处理方式</div>
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">补充说明（可选）</label>
      <div class="controls">
        {{textarea 
          value=additionalNotes 
          placeholder="其他需要说明的内容"
          class="lottery-textarea"
          rows="2"
          maxlength="300"
        }}
      </div>
    </div>
  </div>

  <div class="modal-footer">
    {{d-button 
      action=(action "submit")
      disabled=(not (isValid))
      isLoading=isLoading
      class="btn-primary"
      label=(if isLoading "正在处理..." "插入抽奖")
    }}
    {{d-button 
      action=(action "cancel")
      disabled=isLoading
      class="btn-flat"
      label="取消"
    }}
  </div>
{{/d-modal-body}}
