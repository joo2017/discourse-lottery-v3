<DModal 
  @title="创建抽奖活动" 
  @closeModal={{this.cancelLottery}} 
  class="lottery-settings-modal"
>
  <:body>
    <div class="lottery-form">
      <div class="form-group">
        <label>活动名称 *</label>
        <input 
          type="text" 
          {{on "input" this.updatePrizeName}}
          value={{this.prizeName}}
          placeholder="请输入活动名称"
        />
      </div>

      <div class="form-group">
        <label>奖品说明 *</label>
        <textarea 
          {{on "input" this.updatePrizeDetails}}
          value={{this.prizeDetails}}
          placeholder="请详细描述奖品内容"
          rows="3"
        ></textarea>
      </div>

      <div class="form-group">
        <label>开奖时间 *</label>
        <input 
          type="datetime-local" 
          {{on "input" this.updateDrawTime}}
          value={{this.drawTime}}
        />
      </div>

      <div class="form-group">
        <label>获奖人数 *</label>
        <input 
          type="number" 
          {{on "input" this.updateWinnersCount}}
          value={{this.winnersCount}}
          min="1"
        />
        <small>随机抽奖时的获奖人数</small>
      </div>

      <div class="form-group">
        <label>指定中奖楼层（可选）</label>
        <input 
          type="text" 
          {{on "input" this.updateSpecifiedPosts}}
          value={{this.specifiedPosts}}
          placeholder="例如：8, 18, 28"
        />
        <small>填写此项将覆盖随机抽奖</small>
      </div>

      <div class="form-group">
        <label>参与门槛 *</label>
        <input 
          type="number" 
          {{on "input" this.updateMinParticipants}}
          value={{this.minParticipants}}
          min={{this.globalMinParticipants}}
        />
        <small>最少需要 {{this.globalMinParticipants}} 人参与</small>
      </div>

      <div class="form-group">
        <label>后备策略 *</label>
        <select {{on "change" this.updateBackupStrategy}}>
          <option value="continue" selected={{eq this.backupStrategy "continue"}}>
            人数不足时继续开奖
          </option>
          <option value="cancel" selected={{eq this.backupStrategy "cancel"}}>
            人数不足时取消活动
          </option>
        </select>
      </div>

      <div class="form-group">
        <label>补充说明（可选）</label>
        <textarea 
          {{on "input" this.updateAdditionalNotes}}
          value={{this.additionalNotes}}
          placeholder="其他需要说明的内容"
          rows="2"
        ></textarea>
      </div>
    </div>
  </:body>

  <:footer>
    <DButton 
      @action={{this.confirmLottery}}
      @disabled={{not this.isFormValid}}
      class="btn-primary"
    >
      创建抽奖
    </DButton>
    
    <DButton 
      @action={{this.cancelLottery}}
      class="btn-default"
    >
      取消
    </DButton>
  </:footer>
</DModal>
